{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "china-access-check",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-06",
  "routes": [
    { "pattern": "cn.palemoky.com", "custom_domain": true }
  ],
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "none",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  }
}
